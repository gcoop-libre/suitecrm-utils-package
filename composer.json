{
    "name": "gcoop/suitecrm-utils",
    "description": "Utilidades para desarrollar en SuiteCRM",
    "type": "library",
    "require": {
        "php": "^8.0",
        "kevinrob/guzzle-cache-middleware": "^7.0",
        "symfony/cache": "^6.4",
        "frnde/guzzle_logger": "^3.0",
        "spatie/array-to-xml": "^3.4",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^4.8 || ^9.5"
    },
    "license": "GPLv3",
    "authors": [
        {
            "name": "Jose C. Massón",
            "email": "jose@gcoop.coop"
        }
    ],
    "autoload": {
        "psr-4": {
            "Gcoop\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gcoop\\Tests\\": "tests/",
            "Gcoop\\": "src"
        }
    }
}
